 */
programa
{
	
	funcao inicio()
	{
		inteiro base_triangulo, altura_triangulo, area
		escreva("Calculando a area do triangulo\n\n\n")
		escreva("Qual a o tamanho da base do triangulo?")
		leia(base_triangulo)
		escreva("Qual é a altura do triangulo?")
		leia(altura_triangulo)
	 	area = base_triangulo*altura_triangulo/2
		escreva("\n\nA area do triangulo e igual a ",area)
		
	}
}
